# Hydrogen / Shopify Storefront API. mock.shop returns demo data with no auth.
SESSION_SECRET=foobar
PUBLIC_STORE_DOMAIN=mock.shop
PUBLIC_STOREFRONT_API_TOKEN=
PUBLIC_STOREFRONT_ID=
PUBLIC_CHECKOUT_DOMAIN=
SHOP_ID=

# Customer Account API. Powers /account/* sign-in, orders, dashboard.
# Pulled from Shopify admin > Hydrogen storefronts > Storefront API +
# Customer Account API settings. Sign-in with Google is configured on
# the Shopify side under Settings > Customer accounts > Login providers.
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=

# TallyTails environment variables. All optional. Empty values keep the
# integration "off". The site renders mock data and gracefully no-ops on
# server actions. Populate any group to turn that integration on.

# --- Public (bundled into the client) -----------------------------------

# Shopify Storefront API. Read-only, safe in the browser.
PUBLIC_SHOPIFY_DOMAIN=
PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
PUBLIC_SHOPIFY_API_VERSION=2025-01

# Klaviyo public side. The waitlist list ID is also public.
PUBLIC_KLAVIYO_PUBLIC_KEY=
PUBLIC_KLAVIYO_WAITLIST_LIST_ID=

# Analytics
PUBLIC_META_PIXEL_ID=
PUBLIC_GA4_MEASUREMENT_ID=

# Stripe publishable. PORTFOLIO RULE: only use sk_test_* + pk_test_* keys.
PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Server-only --------------------------------------------------------

# Stripe secret. The createCheckoutSession helper will refuse anything
# that does not start with "sk_test_".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Klaviyo private API key (server-side list mutations).
KLAVIYO_PRIVATE_KEY=

# ShipStation. Quote-only in this app. Never books a real shipment.
SHIPSTATION_API_KEY=
SHIPSTATION_API_SECRET=

# Resend transactional email.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=
